                                                                                                                        <field name="TEXT">I write this to you to show that there is one last hope </field>
                                                                                                                      </shadow>
                                                                                                                    </value>
                                                                                                                    <next>
                                                                                                                      <block type="device_pause" id="(.N6-2:V]*.e7Vgw+00*">
                                                                                                                        <value name="pause">
                                                                                                                          <shadow type="timePicker" id="k9~zG0!R*mi3t-@ryb-d">
                                                                                                                            <field name="ms">1000</field>
                                                                                                                          </shadow>
                                                                                                                        </value>
                                                                                                                        <next>
                                                                                                                          <block type="adv_add_to_text_log" id="|}E6ju)Q(Qd.db|:^nD9">
                                                                                                                            <value name="text">
                                                                                                                              <shadow type="text" id="bsNmiw2Ex_lJPp|+Ftx,">
                                                                                                                                <field name="TEXT">In the other side of the mountains, far away from this cave there are two baby blue dragons</field>
                                                                                                                              </shadow>
                                                                                                                            </value>
                                                                                                                            <next>
                                                                                                                              <block type="device_pause" id="RQNe*i,,hHr@Y2|i1]L+">
                                                                                                                                <value name="pause">
                                                                                                                                  <shadow type="timePicker" id="PjhArJ3i0C_NfUFvL0qw">
                                                                                                                                    <field name="ms">1000</field>
                                                                                                                                  </shadow>
                                                                                                                                </value>
                                                                                                                                <next>
                                                                                                                                  <block type="adv_add_to_text_log" id="~my=Hs5_ML`0x-X*9z#v">
                                                                                                                                    <value name="text">
                                                                                                                                      <shadow type="text" id="`^Q3@tk%)K6Eh}Sr39{|">
                                                                                                                                        <field name="TEXT">you need to save them of the hands of Dekaham, the king of the red spirits, which its only objecttive is to destroy the blue dragons</field>
                                                                                                                                      </shadow>
                                                                                                                                    </value>
                                                                                                                                    <next>
                                                                                                                                      <block type="device_pause" id="N=}De?b%SeIz,[En{z|Y">
                                                                                                                                        <value name="pause">
                                                                                                                                          <shadow type="timePicker" id="o[B}}pfZG)W8iovrRU6q">
                                                                                                                                            <field name="ms">1000</field>
                                                                                                                                          </shadow>
                                                                                                                                        </value>
                                                                                                                                        <next>
                                                                                                                                          <block type="adv_add_to_text_log" id="[ykJy}]2KYC0h6rhnt6G">
                                                                                                                                            <value name="text">
                                                                                                                                              <shadow type="text" id="C.EIf$C=,?7Z15@:W~3?">
                                                                                                                                                <field name="TEXT">now save your specie or wait till the end of you and the blue dragons</field>
                                                                                                                                              </shadow>
                                                                                                                                            </value>
                                                                                                                                          </block>
                                                                                                                                        </next>
                                                                                                                                      </block>
                                                                                                                                    </next>
                                                                                                                                  </block>
                                                                                                                                </next>
                                                                                                                              </block>
